# Database — local Docker Postgres (see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/simplecrm"

# Auth — JWT signing secret (min 32 characters)
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Email — Resend transactional email service
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Public app URL — used for links in emails and capture forms
NEXT_PUBLIC_APP_URL="http://localhost:3000"
